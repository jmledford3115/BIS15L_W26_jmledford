wolves <- read_csv("data/wolves_data/wolves_dataset.csv") %>% clean_names()
wolves %>%
filter(sex!="NA") %>%
ggplot(aes(x=sex, fill=sex))+
geom_bar()+
facet_wrap(~pop)
ui <- dashboardPage(
dashboardHeader(title="Sex Composition by Wolf Population"),
dashboardSidebar(disable=T),
dashboardBody(
selectInput("x",
"Select Population",
choices=sort(unique(wolves$pop)),
selected="AK.PEN"),
plotOutput("plot", width="500px", height="400px")
)
)
server <- function(input, output, session) {
output$plot <- renderPlot({
wolves %>%
filter(pop == input$x) %>%
ggplot(aes(x=sex, fill=sex))+
geom_bar(alpha=0.8, color="black")+
labs(x="Sex", y=NULL)+
theme_minimal()
})
}
shinyApp(ui, server)
ui <- dashboardPage(
dashboardHeader(title="Sex Composition by Wolf Population"),
dashboardSidebar(disable=T),
dashboardBody(
selectInput("x",
"Select Population",
choices=sort(unique(wolves$pop)), #no need to type every pop
selected="AK.PEN"),
plotOutput("plot", width="500px", height="400px")
)
)
server <- function(input, output, session) {
output$plot <- renderPlot({
wolves %>%
filter(pop == input$x) %>%
ggplot(aes(x=sex, fill=sex))+
geom_bar(alpha=0.8, color="black")+
labs(x="Sex", y=NULL)+
theme_minimal()
})
}
shinyApp(ui, server)
