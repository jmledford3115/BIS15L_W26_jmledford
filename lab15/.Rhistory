library(tidyverse)
library(shiny)
library(shinydashboard)
library(janitor)
gestation <- read_csv("data/Data_S1.csv") %>%
clean_names() %>%
rename(gestationlength=gestationength)
names(gestation)
library(shiny)
ui <- fluidPage(
titlePanel("Distribution of Gestation Length by Order"),
selectInput("x",
"Select Order",
choices=sort(unique(gestation$order)),
selected="Afrosoricida"),
selectInput("y",
"Select Variable",
choices = c("bodymass", "longevity", "gestationlength"),
selected="gestationlength"),
plotOutput("plot", width="500px", height="400px")
)
server <- function(input, output, session) {
}
shinyApp(ui, server)
library(shiny)
ui <- fluidPage(
titlePanel("Distribution of Gestation Length by Order"),
selectInput("x",
"Select Order",
choices=sort(unique(gestation$order)),
selected="Afrosoricida"),
selectInput("y",
"Select Variable",
choices = c("bodymass", "longevity", "gestationlength"),
selected="gestationlength"),
helpText("Thodoris Danis, Antonis Rokas; The evolution of gestation length in eutherian mammals. Proc. Biol. Sci. 1 October 2024; 291 (2033): 20241412. https://doi.org/10.1098/rspb.2024.1412"),
plotOutput("plot", width="500px", height="400px")
)
server <- function(input, output, session) {
}
shinyApp(ui, server)
ui <- fluidPage(
titlePanel("Distribution of Gestation Length by Order"),
selectInput("x",
"Select Order",
choices=sort(unique(gestation$order)),
selected="Afrosoricida"),
selectInput("y",
"Select Variable",
choices = c("bodymass", "longevity", "gestationlength"),
selected="gestationlength"),
helpText("Thodoris Danis, Antonis Rokas; The evolution of gestation length in eutherian mammals. Proc. Biol. Sci. 1 October 2024; 291 (2033): 20241412. https://doi.org/10.1098/rspb.2024.1412"),
plotOutput("plot", width="500px", height="400px")
)
server <- function(input, output, session) {
output$plot <- renderPlot({
gestation %>%
filter(input$x==.data[["order"]]) %>%
ggplot(aes(.data[[input$y]]))+
geom_density(fill="steelblue",
color="black",
alpha=0.6)+
theme_minimal()
})
}
shinyApp(ui, server)
ui <-
