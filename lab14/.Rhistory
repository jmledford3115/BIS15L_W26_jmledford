ui <- page_sidebar(
title = "Homerange Data Visualization",
sidebar = sidebar(
radioButtons("x",
"Select Fill Variable",
choices = c("Trophic Guild" = "trophic_guild",
"Thermoregulation" = "thermoregulation"),
selected = "trophic_guild")
),
card(
card_header("Distribution by Locomotion"),
plotOutput("plot", height = "500px")
)
)
server <- function(input, output, session) {
output$plot <- renderPlot({
# Check if homerange dataset exists
if (!exists("homerange")) {
plot.new()
text(0.5, 0.5, "homerange dataset not found\nPlease load the dataset first",
cex = 1.5)
return()
}
ggplot(data = homerange,
aes(x = locomotion, fill = .data[[input$x]])) +
geom_bar(position = "dodge", alpha = 0.8, color = "black") +
labs(x = "Locomotion",
y = "Count",
fill = "Fill Variable") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
})
}
shinyApp(ui, server)
