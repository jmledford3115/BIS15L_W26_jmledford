spiders <- read_csv("data/spiders_with_locs.csv")%>%
clean_names() %>%
filter(latitude<=42)
names(spiders)
View(spiders)
spiders %>%
select(latitude, longitude)
spiders %>%
select(latitude, longitude) %>%
summary()
lat <- c(34.67, 41.80)
long <- c(-124.1, -115.5)
bbox <- make_bbox(long, lat, f=0.03)
map1 <- get_stadiamap(bbox, maptype="stamen_terrain", zoom = 7)
ggmap(map1)
map1 <- get_stadiamap(bbox, maptype="stamen_terrain", zoom = 5)
ggmap(map1)
map1 <- get_stadiamap(bbox, maptype="stamen_terrain", zoom = 8)
ggmap(map1)
map1 <- get_stadiamap(bbox, maptype="stamen_terrain", zoom = 7)
ggmap(map1)
ggmap(map1) %>%
geom_point(data=spiders, aes(longitude, latitude), size=0.75, color="black", alpha=0.8)+
labs(x="Longitude", y="Latitude", title="CA Usofila Records")
ggmap(map1) +
geom_point(data=spiders, aes(longitude, latitude), size=0.75, color="black", alpha=0.8)+
labs(x="Longitude", y="Latitude", title="CA Usofila Records")
ggmap(map1) +
geom_point(data=spiders, aes(longitude, latitude), size=1, color="black", alpha=0.8)+
labs(x="Longitude", y="Latitude", title="CA Usofila Records")
ggmap(map1) +
geom_point(data=spiders, aes(longitude, latitude), size=1, color="red", alpha=0.8)+
labs(x="Longitude", y="Latitude", title="CA Usofila Records")
spiders %>%
lon_min=min(longitude, na.rm=T)
spiders
spiders %>%
summarize(
lon_min=min(longitude, na.rm=T))
spiders %>%
summarize(
lon_min=min(longitude, na.rm=T),
lon_max=max(longitude, na.rm=T),
lat_min=min(latitude, na.rm=T),
lat_max=max(latitude, na.rm=T))
lon_min <- -124.13
lon_max <- -115.49
lat_min <- 34.67
lat_max <- 41.8
leaflet(spiders) %>%
addProviderTiles(providers$Stadia.StamenTerrain) %>%
addCircleMarkers(
lng = ~longitude,
lat = ~latitude,
radius=2,
stroke = FALSE,
fillOpacity=0.7
) %>%
addScaleBar(position="bottomleft") %>%
fitBounds(lng1=lon_min, lat1=lat_min,
lng2=lon_max, lat2=lat_max)
leaflet(spiders) %>%
addTiles() %>%
addCircleMarkers(
lng = ~longitude,
lat = ~latitude,
radius=2,
stroke = FALSE,
fillOpacity=0.7
) %>%
addScaleBar(position="bottomleft") %>%
fitBounds(lng1=lon_min, lat1=lat_min,
lng2=lon_max, lat2=lat_max)
grizzly <- read_csv("data/bear-sightings.csv")
names(grizzly)
grizzly %>%
select(latitude, longitude) %>%
summary()
lat <- c(55.02, 70.37)
long <- c(-131.3, -166.2)
lat <- c(55.02, 70.37)
long <- c(-131.3, -166.2)
bbox <- make_bbox(long, lat, f=0.05)
map1 <- get_stadiamap(bbox, maptype="stamen_terrain", zoom=5)
ggmap(map1)
ggmap(map1)+
geom_point(data=grizzly, aes(longitude, latitude), size=0.8)+
labs(x="Longitude", y="Latitude", title="Ursos horriblus")
